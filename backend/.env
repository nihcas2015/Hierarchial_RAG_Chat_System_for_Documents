# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/document_rag_db

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production

# API Settings
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# LangChain Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
K_DOCUMENTS=5  # Number of documents to retrieve for RAG

# ===== CONTEXTUAL RAG WITH LANGGRAPH =====

# Ollama Local Model Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # Use: llama2, neural-chat, dolphin-mixtral, etc.

# Gemini API Configuration (for global meaning)
GEMINI_API_KEY=your-gemini-api-key-here

# Contextual RAG Settings
K_CHUNKS_CONTEXTUAL=3  # Number of chunks to retrieve for contextual analysis
CHUNK_SUMMARIZATION_ENABLED=True  # Enable Ollama summarization
CHUNK_RELATIONSHIP_ANALYSIS_ENABLED=True  # Build LangGraph relationships
GEMINI_GLOBAL_CONTEXT_ENABLED=True  # Get global meaning with Gemini
