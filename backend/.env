# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/document_rag_db

# JWT Secret
SECRET_KEY=your-secret-key-change-this-in-production

# API Settings
API_HOST=0.0.0.0
API_PORT=5000
DEBUG=True

# LangChain Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
K_DOCUMENTS=5  # Number of documents to retrieve for RAG

# ===== CONTEXTUAL RAG WITH LANGGRAPH (NO OPENAI) =====

# Ollama Local Model Configuration (ALL AI TASKS)
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# Gemini API Configuration (GLOBAL CONTEXT ONLY)
GEMINI_API_KEY=AIzaSyA6CjsnV7R2CEh9A7fumPn12xKTjdnnPcE
GEMINI_MODEL=gemini-3.1-flash-lite

# Local Embeddings (No API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Local sentence-transformers model

# Contextual RAG Settings
K_CHUNKS_CONTEXTUAL=3
CHUNK_SUMMARIZATION_ENABLED=True
CHUNK_RELATIONSHIP_ANALYSIS_ENABLED=True
GEMINI_GLOBAL_CONTEXT_ENABLED=True
